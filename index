<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clinical MCQ Quiz — Neurosurgery & Urology</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #eef1f5;
    --bg-card: #ffffff;
    --ink: #1a1a1a;
    --ink-soft: #5a5a5a;
    --line: #d8dde5;
    --accent: #3a5878;
    --selected: #e3ebf4;
    --correct: #5a7d3e;
    --correct-bg: #eef3e4;
    --wrong: #b5483c;
    --wrong-bg: #f7e6e3;
    --shadow: 0 2px 12px rgba(0,0,0,0.04);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    padding: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .container { max-width: 640px; margin: 0 auto; }

  /* Start screen */
  .start-screen {
    text-align: center;
    padding: 48px 20px;
  }
  .start-screen h1 {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 36px;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .start-screen .subtitle {
    color: var(--ink-soft);
    font-size: 16px;
    margin-bottom: 32px;
  }
  .info-card {
    background: var(--bg-card);
    border-radius: 14px;
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 24px;
    text-align: left;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }
  .info-row:last-child { border-bottom: none; }
  .info-row .label { color: var(--ink-soft); }
  .info-row .value { font-weight: 600; }
  .topics-list {
    color: var(--ink-soft);
    font-size: 14px;
    margin-top: 12px;
    line-height: 1.7;
  }
  .topics-list strong { color: var(--ink); font-weight: 600; }

  /* Quiz screen */
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-size: 13px;
    color: var(--ink-soft);
  }
  .progress-bar {
    height: 4px;
    background: var(--line);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width 0.3s ease;
  }
  .topic-tag {
    display: inline-block;
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .question-card {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 24px 22px;
    box-shadow: var(--shadow);
    margin-bottom: 16px;
  }
  .question-text {
    font-family: 'Fraunces', serif;
    font-size: 19px;
    font-weight: 500;
    line-height: 1.45;
    margin-bottom: 22px;
    color: var(--ink);
  }
  .options { display: flex; flex-direction: column; gap: 10px; }
  .option {
    background: var(--bg);
    border: 1.5px solid var(--line);
    border-radius: 10px;
    padding: 14px 16px;
    cursor: pointer;
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
    text-align: left;
    transition: all 0.15s ease;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    line-height: 1.4;
  }
  .option:hover { border-color: var(--accent); background: #e8edf3; }
  .option.selected {
    background: var(--selected);
    border-color: var(--accent);
  }
  .option-letter {
    background: var(--bg-card);
    border: 1.5px solid var(--line);
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 12px;
    flex-shrink: 0;
    color: var(--ink-soft);
  }
  .option.selected .option-letter {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .actions {
    display: flex;
    gap: 10px;
    margin-top: 12px;
  }
  .btn {
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 14px 22px;
    cursor: pointer;
    font-family: inherit;
    font-size: 15px;
    font-weight: 500;
    flex: 1;
    transition: all 0.15s ease;
  }
  .btn:active { transform: scale(0.98); }
  .btn:hover { background: #333; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-secondary {
    background: transparent;
    color: var(--ink-soft);
    border: 1.5px solid var(--line);
  }
  .btn-secondary:hover { background: var(--bg-card); color: var(--ink); }
  .btn-submit { background: var(--correct); }
  .btn-submit:hover { background: #4a6b32; }

  /* Results */
  .results-header {
    text-align: center;
    padding: 24px 16px 16px;
  }
  .results-header h2 {
    font-family: 'Fraunces', serif;
    font-size: 32px;
    margin-bottom: 8px;
    font-weight: 600;
  }
  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 4px solid var(--accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 16px auto;
    box-shadow: var(--shadow);
  }
  .score-num {
    font-family: 'Fraunces', serif;
    font-size: 44px;
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }
  .score-total { font-size: 13px; color: var(--ink-soft); margin-top: 4px; }
  .score-msg { color: var(--ink-soft); font-size: 15px; margin-bottom: 20px; text-align: center; }
  .review-section { margin-top: 24px; }
  .review-heading {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 16px;
    padding-left: 4px;
  }
  .review-item {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 20px 18px;
    box-shadow: var(--shadow);
    margin-bottom: 12px;
  }
  .review-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    gap: 8px;
  }
  .review-num {
    font-size: 12px;
    color: var(--ink-soft);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .review-status {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .review-status.correct { background: var(--correct-bg); color: var(--correct); }
  .review-status.wrong { background: var(--wrong-bg); color: var(--wrong); }
  .review-status.skipped { background: var(--line); color: var(--ink-soft); }
  .review-q {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.45;
    margin-bottom: 14px;
  }
  .review-answer-row {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    margin-bottom: 8px;
    font-size: 14px;
    line-height: 1.45;
  }
  .review-answer-row .label {
    font-weight: 600;
    flex-shrink: 0;
    min-width: 75px;
    color: var(--ink-soft);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .review-answer-row .answer { flex: 1; }
  .review-answer-row .answer.your-correct { color: var(--correct); font-weight: 600; }
  .review-answer-row .answer.your-wrong { color: var(--wrong); font-weight: 600; }
  .review-answer-row .answer.correct-ans { color: var(--correct); font-weight: 600; }
  .review-explanation {
    margin-top: 14px;
    padding: 12px 14px;
    background: #eef2f7;
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    font-size: 14px;
    line-height: 1.55;
  }
  .review-topic {
    display: inline-block;
    background: var(--bg);
    padding: 2px 8px;
    border-radius: 8px;
    font-size: 10px;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .hidden { display: none; }
</style>
</head>
<body>
  <div class="container">

    <!-- Start screen -->
    <div id="start-screen">
      <div class="start-screen">
        <h1>Clinical MCQs</h1>
        <p class="subtitle">Neurosurgery &amp; Urology</p>
        <div class="info-card">
          <div class="info-row"><span class="label">Questions</span><span class="value">20</span></div>
          <div class="info-row"><span class="label">Time</span><span class="value">No limit</span></div>
          <div class="info-row"><span class="label">Format</span><span class="value">Single best answer</span></div>
          <div class="topics-list">
            <strong>Topics covered:</strong><br>
            • Spine Dysraphism — 5 Qs<br>
            • Bladder Tumors — 5 Qs<br>
            • Prostate — 5 Qs<br>
            • Penile Tumors — 5 Qs
          </div>
        </div>
        <button class="btn" onclick="startQuiz()">Begin Quiz</button>
      </div>
    </div>

    <!-- Quiz screen -->
    <div id="quiz-screen" class="hidden">
      <div class="top-bar">
        <span id="progress-text">Question 1 of 20</span>
        <span class="topic-tag" id="current-topic"></span>
      </div>
      <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>

      <div class="question-card">
        <div class="question-text" id="question-text"></div>
        <div class="options" id="options"></div>
      </div>

      <div class="actions">
        <button class="btn btn-secondary" id="prev-btn" onclick="prevQuestion()">← Back</button>
        <button class="btn" id="next-btn" onclick="nextQuestion()">Next →</button>
      </div>
    </div>

    <!-- Results -->
    <div id="results-screen" class="hidden">
      <div class="results-header">
        <h2>Your Results</h2>
        <p class="subtitle" style="color: var(--ink-soft); font-size: 15px;">Neurosurgery &amp; Urology</p>
        <div class="score-circle">
          <div class="score-num" id="score-num">0</div>
          <div class="score-total" id="score-total">of 20</div>
        </div>
        <p class="score-msg" id="score-message"></p>
      </div>

      <div class="review-section">
        <h3 class="review-heading">Answer Review</h3>
        <div id="review-list"></div>
      </div>

      <div class="actions" style="margin-top: 24px; margin-bottom: 24px;">
        <button class="btn btn-secondary" onclick="restartQuiz()">Retake Quiz</button>
      </div>
    </div>
  </div>

<script>
const QUESTIONS = [
  // SPINE DYSRAPHISM
  {
    topic: "Spine Dysraphism",
    q: "The form of spinal dysraphism with a skin defect, exposed neural tissue, and meninges is:",
    options: ["Spina bifida occulta", "Meningocele", "Myelomeningocele", "Lipomyelocele"],
    answer: 2,
    explanation: "Myelomeningocele = open neural tube defect with exposed neural placode. The most severe form; usually causes neurologic deficits below the lesion."
  },
  {
    topic: "Spine Dysraphism",
    q: "Folic acid supplementation prevents neural tube defects when started:",
    options: ["After pregnancy is confirmed", "End of first trimester", "Before conception, ideally ≥3 months prior", "Throughout pregnancy only"],
    answer: 2,
    explanation: "The neural tube closes by day 28 post-conception, often before pregnancy is even recognized. Prevention requires preconception folate supplementation."
  },
  {
    topic: "Spine Dysraphism",
    q: "The condition most commonly associated with myelomeningocele:",
    options: ["Chiari II malformation with hydrocephalus", "Cerebral palsy", "Down syndrome", "Spinal muscular atrophy"],
    answer: 0,
    explanation: "Chiari II (herniation of cerebellum and brainstem through foramen magnum) occurs in nearly all myelomeningoceles, causing hydrocephalus that often needs VP shunting."
  },
  {
    topic: "Spine Dysraphism",
    q: "A child has a hairy patch, dimple, or lipoma over the lumbar spine but no neurologic deficit. Most likely:",
    options: ["Myelomeningocele", "Spina bifida occulta", "Tethered cord syndrome", "Encephalocele"],
    answer: 1,
    explanation: "Spina bifida occulta — failed vertebral arch fusion with intact skin. Cutaneous stigmata (tuft of hair, dimple, lipoma, hemangioma) are clues. May still need imaging to rule out tethered cord."
  },
  {
    topic: "Spine Dysraphism",
    q: "A child with previously repaired myelomeningocele develops progressive lower limb weakness, back pain, and bladder dysfunction. Most likely:",
    options: ["Recurrent infection", "Tethered cord syndrome", "Spinal cord tumor", "Chiari decompensation"],
    answer: 1,
    explanation: "As the child grows, scar tissue tethers the cord and produces traction. Triad: progressive motor/sensory deficit, sphincter dysfunction, pain. MRI confirms; surgery releases the cord."
  },

  // BLADDER TUMORS
  {
    topic: "Bladder Tumor",
    q: "Most common histologic type of bladder cancer in developed countries:",
    options: ["Squamous cell carcinoma", "Adenocarcinoma", "Urothelial (transitional cell) carcinoma", "Small cell carcinoma"],
    answer: 2,
    explanation: "Urothelial carcinoma accounts for over 90% of bladder cancers in non-endemic regions. Strongly linked to smoking and aromatic amine exposure."
  },
  {
    topic: "Bladder Tumor",
    q: "In regions endemic for schistosomiasis (e.g., Egypt, parts of Africa), the most common bladder cancer is:",
    options: ["Urothelial carcinoma", "Squamous cell carcinoma", "Adenocarcinoma", "Sarcoma"],
    answer: 1,
    explanation: "Chronic infection with Schistosoma haematobium causes chronic inflammation → squamous metaplasia → SCC. Squamous cell carcinoma dominates in endemic regions."
  },
  {
    topic: "Bladder Tumor",
    q: "The classic presentation of bladder cancer is:",
    options: ["Painful hematuria", "Painless gross hematuria", "Bilateral flank pain", "Pneumaturia"],
    answer: 1,
    explanation: "Painless visible hematuria is the hallmark. Until proven otherwise, painless gross hematuria in an adult is bladder cancer."
  },
  {
    topic: "Bladder Tumor",
    q: "Gold standard diagnostic investigation for a suspected bladder tumor:",
    options: ["Urine cytology", "Bladder ultrasound", "CT urogram", "Cystoscopy with biopsy"],
    answer: 3,
    explanation: "Cystoscopy directly visualizes the tumor and allows biopsy for histology. Cytology and imaging are supportive but never replace cystoscopy."
  },
  {
    topic: "Bladder Tumor",
    q: "Intravesical BCG immunotherapy is indicated in:",
    options: ["Muscle-invasive bladder cancer", "Metastatic bladder cancer", "High-grade non-muscle-invasive (superficial) bladder cancer", "Pure adenocarcinoma of bladder"],
    answer: 2,
    explanation: "BCG instilled into the bladder triggers a local immune response, reducing recurrence and progression in high-risk superficial disease. Muscle-invasive disease needs cystectomy."
  },

  // PROSTATE
  {
    topic: "Prostate",
    q: "Most common histologic type of prostate cancer:",
    options: ["Squamous cell carcinoma", "Transitional cell carcinoma", "Adenocarcinoma", "Sarcoma"],
    answer: 2,
    explanation: "Over 95% of prostate cancers are acinar adenocarcinomas arising from the glandular epithelium."
  },
  {
    topic: "Prostate",
    q: "Prostate cancer most commonly arises in which zone:",
    options: ["Central zone", "Transition zone", "Peripheral zone", "Anterior fibromuscular stroma"],
    answer: 2,
    explanation: "Peripheral zone — which is why a hard nodule is palpable on DRE. BPH, by contrast, arises from the transition zone (which is why it causes obstructive symptoms early)."
  },
  {
    topic: "Prostate",
    q: "Prostate cancer typically metastasizes to bone, producing which type of lesion:",
    options: ["Osteolytic", "Osteoblastic", "Mixed lytic-blastic", "Pathological fractures only"],
    answer: 1,
    explanation: "Osteoblastic (sclerotic, dense) lesions on X-ray. Classic spread is to the lumbar vertebrae via Batson's venous plexus. Raised ALP supports the diagnosis."
  },
  {
    topic: "Prostate",
    q: "The Gleason score is based on:",
    options: ["Tumor size", "Serum PSA level", "Architectural pattern of tumor (sum of the two most prevalent grades)", "Lymph node involvement"],
    answer: 2,
    explanation: "Gleason = sum of the two most prevalent histologic patterns, each graded 1-5. Higher scores = worse differentiation and prognosis. PSA and staging are separate parameters."
  },
  {
    topic: "Prostate",
    q: "A 65-year-old has PSA 12 ng/mL and a hard nodule on DRE. Best next investigation:",
    options: ["Repeat PSA in 6 weeks", "Transrectal ultrasound-guided prostate biopsy", "Bone scan", "Pelvic CT"],
    answer: 1,
    explanation: "Elevated PSA + abnormal DRE strongly suggests cancer. Tissue diagnosis is required — TRUS-guided biopsy (or increasingly MRI-targeted) is the standard."
  },

  // PENILE TUMORS
  {
    topic: "Penile Tumor",
    q: "Most common malignancy of the penis:",
    options: ["Adenocarcinoma", "Squamous cell carcinoma", "Basal cell carcinoma", "Melanoma"],
    answer: 1,
    explanation: "Over 95% of penile cancers are squamous cell carcinoma, arising from the glans or inner prepuce."
  },
  {
    topic: "Penile Tumor",
    q: "The single most strongly protective factor against penile cancer is:",
    options: ["Smoking cessation", "Neonatal circumcision", "HPV vaccination", "Diabetes control"],
    answer: 1,
    explanation: "Neonatal circumcision dramatically reduces lifetime risk. Phimosis, poor hygiene, HPV infection, and smoking are risk factors."
  },
  {
    topic: "Penile Tumor",
    q: "The HPV subtypes most strongly associated with penile carcinoma are:",
    options: ["HPV 6 and 11", "HPV 16 and 18", "HPV 1 and 2", "HPV 31 only"],
    answer: 1,
    explanation: "High-risk types HPV 16 and 18 cause anogenital squamous cancers (cervix, anus, penis, oropharynx). HPV 6 and 11 cause genital warts but not cancer."
  },
  {
    topic: "Penile Tumor",
    q: "Penile cancer primarily metastasizes via lymphatics to:",
    options: ["Para-aortic nodes", "Internal iliac nodes", "Inguinal lymph nodes", "Mediastinal nodes"],
    answer: 2,
    explanation: "Superficial then deep inguinal nodes are the first stations. Palpable inguinal lymphadenopathy is a key staging finding."
  },
  {
    topic: "Penile Tumor",
    q: "A patient presents with a large cauliflower-like exophytic penile mass that is locally destructive but rarely metastasizes. Diagnosis:",
    options: ["Well-differentiated SCC", "Buschke-Löwenstein tumor (giant condyloma)", "Bowen disease", "Erythroplasia of Queyrat"],
    answer: 1,
    explanation: "Buschke-Löwenstein = giant verrucous tumor associated with HPV 6/11. Locally aggressive but rarely metastasizes. Bowen disease and Erythroplasia of Queyrat are SCC in situ."
  }
];

let currentIndex = 0;
let userAnswers = new Array(QUESTIONS.length).fill(null);

function startQuiz() {
  document.getElementById('start-screen').classList.add('hidden');
  document.getElementById('quiz-screen').classList.remove('hidden');
  currentIndex = 0;
  userAnswers = new Array(QUESTIONS.length).fill(null);
  renderQuestion();
  window.scrollTo(0, 0);
}

function renderQuestion() {
  const q = QUESTIONS[currentIndex];
  document.getElementById('question-text').textContent = q.q;
  document.getElementById('current-topic').textContent = q.topic;
  document.getElementById('progress-text').textContent = `Question ${currentIndex + 1} of ${QUESTIONS.length}`;
  document.getElementById('progress-fill').style.width = `${((currentIndex + 1) / QUESTIONS.length) * 100}%`;

  const optionsDiv = document.getElementById('options');
  optionsDiv.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D', 'E'];
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option' + (userAnswers[currentIndex] === i ? ' selected' : '');
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span><span>${opt}</span>`;
    btn.onclick = () => selectOption(i);
    optionsDiv.appendChild(btn);
  });

  document.getElementById('prev-btn').disabled = currentIndex === 0;

  const nextBtn = document.getElementById('next-btn');
  if (currentIndex === QUESTIONS.length - 1) {
    nextBtn.textContent = 'Submit Quiz';
    nextBtn.classList.add('btn-submit');
  } else {
    nextBtn.textContent = 'Next →';
    nextBtn.classList.remove('btn-submit');
  }
}

function selectOption(i) {
  userAnswers[currentIndex] = i;
  renderQuestion();
}

function nextQuestion() {
  if (currentIndex === QUESTIONS.length - 1) {
    if (userAnswers.includes(null)) {
      const unanswered = userAnswers.filter(a => a === null).length;
      if (!confirm(`You have ${unanswered} unanswered question(s). Submit anyway?`)) return;
    }
    showResults();
  } else {
    currentIndex++;
    renderQuestion();
    window.scrollTo(0, 0);
  }
}

function prevQuestion() {
  if (currentIndex > 0) {
    currentIndex--;
    renderQuestion();
    window.scrollTo(0, 0);
  }
}

function showResults() {
  document.getElementById('quiz-screen').classList.add('hidden');
  document.getElementById('results-screen').classList.remove('hidden');

  let score = 0;
  QUESTIONS.forEach((q, i) => { if (userAnswers[i] === q.answer) score++; });

  document.getElementById('score-num').textContent = score;
  document.getElementById('score-total').textContent = `of ${QUESTIONS.length}`;

  const pct = (score / QUESTIONS.length) * 100;
  let msg = '';
  if (pct === 100) msg = "Perfect score. Outstanding work.";
  else if (pct >= 80) msg = `${pct.toFixed(0)}% — strong performance.`;
  else if (pct >= 60) msg = `${pct.toFixed(0)}% — solid effort. Review the misses below.`;
  else if (pct >= 40) msg = `${pct.toFixed(0)}% — some gaps to close. Review and retry.`;
  else msg = `${pct.toFixed(0)}% — worth a careful re-read of these topics.`;
  document.getElementById('score-message').textContent = msg;

  const reviewList = document.getElementById('review-list');
  reviewList.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D', 'E'];
  QUESTIONS.forEach((q, i) => {
    const userAns = userAnswers[i];
    const isCorrect = userAns === q.answer;
    const skipped = userAns === null;

    let statusClass = isCorrect ? 'correct' : (skipped ? 'skipped' : 'wrong');
    let statusText = isCorrect ? 'Correct' : (skipped ? 'Skipped' : 'Incorrect');

    const item = document.createElement('div');
    item.className = 'review-item';
    item.innerHTML = `
      <div class="review-item-header">
        <span class="review-num">Question ${i + 1} <span class="review-topic">${q.topic}</span></span>
        <span class="review-status ${statusClass}">${statusText}</span>
      </div>
      <div class="review-q">${q.q}</div>
      ${skipped ? '' : `
        <div class="review-answer-row">
          <span class="label">Your answer</span>
          <span class="answer ${isCorrect ? 'your-correct' : 'your-wrong'}">${letters[userAns]}. ${q.options[userAns]}</span>
        </div>
      `}
      <div class="review-answer-row">
        <span class="label">Correct</span>
        <span class="answer correct-ans">${letters[q.answer]}. ${q.options[q.answer]}</span>
      </div>
      <div class="review-explanation">${q.explanation}</div>
    `;
    reviewList.appendChild(item);
  });

  window.scrollTo(0, 0);
}

function restartQuiz() {
  document.getElementById('results-screen').classList.add('hidden');
  document.getElementById('start-screen').classList.remove('hidden');
  window.scrollTo(0, 0);
}
</script>
</body>
</html>
